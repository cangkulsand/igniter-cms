<?xml version="1.0"?>
<ruleset name="Igniter CMS — Code Smell Rules"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0
                             http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>
        Ruleset for the UTM Part B code-smell analysis. Uses the standard PHPMD
        rulesets but lowers ExcessiveParameterList's threshold so the targeted
        Long Parameter List (smell #4 — GoogleAuthController::createGoogleUser(),
        5 parameters) is detected. PHPMD's default minimum is 10.
    </description>

    <!-- Code Size: keep all rules except the default-threshold ExcessiveParameterList -->
    <rule ref="rulesets/codesize.xml">
        <exclude name="ExcessiveParameterList"/>
    </rule>

    <!-- Re-add ExcessiveParameterList with a lower threshold (catches >= 5 params) -->
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <priority>1</priority>
        <properties>
            <property name="minimum" value="5"/>
        </properties>
    </rule>

    <rule ref="rulesets/design.xml"/>
    <rule ref="rulesets/cleancode.xml"/>
    <rule ref="rulesets/unusedcode.xml"/>
</ruleset>
